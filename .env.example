# ── LLM providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=...
ANTHROPIC_API_KEY=...
DEFAULT_MODEL=gpt-4.1        # fallback model when not specified per-agent or per-team

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=brandpilot

# ── BrandPilot Backend ────────────────────────────────────────────────────────
BRANDPILOT_API_PRD=https://brandpilot-prd.com/api
BRANDPILOT_API_STG=https://brandpilot-stg.com/api

# ── Cognito (for token refresh — never put actual values in code) ─────────────
COGNITO_CLIENT_ID=...
COGNITO_CLIENT_SECRET=...
COGNITO_DOMAIN_PRD=https://brandpilot-prd-api-domain.auth.eu-central-1.amazoncognito.com
COGNITO_DOMAIN_STG=https://brandpilot-stg-api-domain.auth.eu-central-1.amazoncognito.com
